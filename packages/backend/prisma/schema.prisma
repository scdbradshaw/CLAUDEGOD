// ============================================================
// PRISMA SCHEMA — Civilization Simulation
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --------------- Enums ---------------

enum Sexuality {
  HETEROSEXUAL
  HOMOSEXUAL
  BISEXUAL
  ASEXUAL
  PANSEXUAL
  OTHER
}

enum EmotionalImpact {
  traumatic
  negative
  neutral
  positive
  euphoric
}

enum HeadlineCategory {
  MOST_DRAMATIC_FALL
  MOST_INSPIRING_RISE
  GREATEST_VILLAIN
  MOST_TRAGIC
  BEST_LOVE_STORY
  MOST_CRIMINAL
  RAGS_TO_RICHES
  RICHES_TO_RAGS
  MOST_INFLUENTIAL
  LONGEST_SURVIVING
}

enum HeadlineType {
  ANNUAL
  DECADE
}

enum InnerCircleRelation {
  parent
  child
  sibling
  spouse
  lover
  close_friend
  rival
  enemy
}

enum GroupOrigin {
  emergent
  player
  event
}

// Job lifecycle for the Postgres-as-queue tick runner. Enqueued jobs are
// claimed with an advisory lock; only one worker progresses a job at a time.
enum JobStatus {
  pending
  running
  done
  failed
}

// Scope tag for WorldMemory / GroupMemory reads. Not persisted as a column;
// kept here for type-level symmetry with MemoryBank's per-person scope.
enum MemoryScope {
  religion
  faction
}

enum PopulationTier {
  intimate      // 100–500
  town          // 500–5,000
  civilization  // 5,000–50,000
}

// Voice routing for Claude narration. Determines the voice prefix
// injected into headline / memory / decade prompts.
//   tabloid   — scandals, rises/falls, affairs, forced interactions
//   literary  — deaths, births, quiet beats, natural old-age passing
//   epic      — group founded/dissolved/split, decade summaries
//   reportage — bulk chaos (plague, nukes, bulk God Mode filter actions)
//   neutral   — fallback; terse factual for low-magnitude routine events
enum Tone {
  tabloid
  literary
  epic
  reportage
  neutral
}

// --------------- World ---------------
// Replaces the singleton WorldState. Each World is a fully isolated
// state: its own population, groups, headlines, and economy.

model World {
  id          String    @id @default(uuid()) @db.Uuid
  name        String
  description String?
  is_active   Boolean   @default(false)
  archived_at DateTime?

  population_tier PopulationTier @default(intimate)

  /// The ruleset driving this world's interactions. Nullable so a world
  /// can exist before a ruleset is chosen (picked at creation time in UI).
  ruleset    Ruleset? @relation(fields: [ruleset_id], references: [id], onDelete: SetNull)
  ruleset_id String?  @db.Uuid

  // ── Operational state (was WorldState) ──────────────────────
  current_year              Int    @default(1)
  tick_count                Int    @default(0)
  total_deaths              Int    @default(0)
  market_index              Float  @default(100.0)
  market_trend              Float  @default(0.015)
  market_volatility         Float  @default(0.03)
  /// Flat map of all global trait child values  e.g. { "war.morale": 20 }
  global_traits             Json   @default("{}")
  /// Per-force effect multipliers e.g. { "war": 1.5 }
  global_trait_multipliers  Json   @default("{}")
  /// Which 5 trait categories are active/shown in UI
  active_trait_categories   Json   @default("[]")

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  // ── Per-world entity sets ────────────────────────────────────
  persons        Person[]
  religions      Religion[]
  factions       Faction[]
  deceased       DeceasedPerson[]
  headlines      YearlyHeadline[]
  world_memories WorldMemory[]
  tick_jobs      TickJob[]
  yearly_reports YearlyReport[]
  pregnancies    Pregnancy[]
  city           City?

  @@index([is_active])
  @@map("worlds")
}

// --------------- City ---------------
// Phase 7: single-city container for every world. Future-proofs geography
// without committing to multi-city yet — one row per world, enforced via
// @@unique(world_id). Adding multi-city later means dropping the unique
// and backfilling a city_id column on Person/DeceasedPerson.
model City {
  id          String  @id @default(uuid()) @db.Uuid
  name        String
  description String?
  founded_year Int    @default(1)

  world    World  @relation(fields: [world_id], references: [id], onDelete: Cascade)
  world_id String @unique @db.Uuid

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@map("cities")
}

// --------------- Person ---------------

model Person {
  id   String @id @default(uuid()) @db.Uuid
  name String

  // ── Demographic ──────────────────────────────────────────
  sexuality  Sexuality
  gender     String
  race       String
  occupation String    @default("commoner")
  age        Int
  /// Age at which natural death occurs — rolled from race lifespan at birth
  death_age  Int       @default(80)

  // ── Social ───────────────────────────────────────────────
  relationship_status String
  religion            String
  /// JSONB array of CriminalRecord objects
  criminal_record     Json   @default("[]")

  // ── Vital ────────────────────────────────────────────────
  /// Life/death indicator — synced from traits.health each tick.
  /// 0 = dead; 1-100 = alive. Kept as a column so SQL WHERE health > 0
  /// can use the index without parsing JSONB.
  health Int @default(100) // 0-100

  // ── Trauma (Round 3) ─────────────────────────────────────
  /// Emotional scar tissue accumulated from negative memory writes and
  /// decayed annually on the year-boundary tick. Affects interaction
  /// scoring as a flat subtrahend — a traumatized person's world darkens.
  /// 0-100. Stored as a column (not JSONB) so bulk decay is one UPDATE.
  trauma_score Float @default(0)

  // ── Other ────────────────────────────────────────────────
  physical_appearance String
  /// Floating-point; no enforced upper bound
  wealth              Float  @default(0.0)
  /// JSONB map of all 100 survival/philosophy traits (0-100 each)
  traits              Json   @default("{}")
  /// JSONB map of personal global force scores e.g. { "war.morale": 45 }
  global_scores       Json   @default("{}")

  // ── World ────────────────────────────────────────────────
  world    World  @relation(fields: [world_id], references: [id], onDelete: Cascade)
  world_id String @db.Uuid

  // ── Genealogy (Round 2 — Births) ─────────────────────────
  /// One of the two biological parents. Null for seed / player-injected people.
  parent_a_id String? @db.Uuid
  parent_b_id String? @db.Uuid
  parent_a    Person? @relation("ParentA", fields: [parent_a_id], references: [id], onDelete: SetNull)
  parent_b    Person? @relation("ParentB", fields: [parent_b_id], references: [id], onDelete: SetNull)

  // ── Timestamps ───────────────────────────────────────────
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  // ── Relations ────────────────────────────────────────────
  memory_bank          MemoryBank[]
  life_decade_summaries LifeDecadeSummary[]
  links_out            InnerCircleLink[]    @relation("LinkOwner")
  links_in             InnerCircleLink[]    @relation("LinkTarget")
  founded_religions    Religion[]           @relation("ReligionFounder")
  led_religions        Religion[]           @relation("ReligionLeader")
  religion_memberships ReligionMembership[]
  founded_factions     Faction[]            @relation("FactionFounder")
  led_factions         Faction[]            @relation("FactionLeader")
  faction_memberships  FactionMembership[]
  children_a           Person[]             @relation("ParentA")
  children_b           Person[]             @relation("ParentB")
  pregnancies_a        Pregnancy[]          @relation("PregnancyParentA")
  pregnancies_b        Pregnancy[]          @relation("PregnancyParentB")

  @@index([world_id])
  @@index([parent_a_id])
  @@index([parent_b_id])
  @@map("persons")
}

// --------------- Pregnancies (Round 2 — Births) ---------------
// Created by a positive-band `conception` interaction outcome OR by the
// agentic `attempt_conception` action. Resolves at tick = due_tick by
// creating a child Person via createChildFromParents() and setting
// resolved = true + child_id. A pregnancy whose parent dies before
// resolution is dropped silently (Cascade on both parent foreign keys).
model Pregnancy {
  id String @id @default(uuid()) @db.Uuid

  parent_a    Person @relation("PregnancyParentA", fields: [parent_a_id], references: [id], onDelete: Cascade)
  parent_a_id String @db.Uuid
  parent_b    Person @relation("PregnancyParentB", fields: [parent_b_id], references: [id], onDelete: Cascade)
  parent_b_id String @db.Uuid

  world    World  @relation(fields: [world_id], references: [id], onDelete: Cascade)
  world_id String @db.Uuid

  /// Tick at which the pregnancy began.
  started_tick Int
  /// Tick at which the pregnancy resolves — started_tick + PREGNANCY_DURATION_TICKS.
  due_tick     Int

  resolved Boolean @default(false)
  child_id String? @db.Uuid

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([world_id])
  @@index([resolved, due_tick])
  @@index([parent_a_id])
  @@index([parent_b_id])
  @@map("pregnancies")
}

// --------------- Inner Circle Links ---------------
// Directed per-person relationship edge. Both directions are stored
// as separate rows when a relationship is reciprocal (e.g. siblings).
model InnerCircleLink {
  id String @id @default(uuid()) @db.Uuid

  owner     Person @relation("LinkOwner", fields: [owner_id], references: [id], onDelete: Cascade)
  owner_id  String @db.Uuid
  target    Person @relation("LinkTarget", fields: [target_id], references: [id], onDelete: Cascade)
  target_id String @db.Uuid

  relation_type InnerCircleRelation
  /// 0-100 — drives antagonizer pick weight and interaction colouring
  bond_strength Int                 @default(50)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@unique([owner_id, target_id, relation_type])
  @@index([owner_id])
  @@index([target_id])
  @@map("inner_circle_links")
}

// --------------- Memory Bank ---------------

model MemoryBank {
  id String @id @default(uuid()) @db.Uuid

  person    Person @relation(fields: [person_id], references: [id], onDelete: Cascade)
  person_id String @db.Uuid

  event_summary    String
  emotional_impact EmotionalImpact

  /// Snapshot of the PersonDelta that triggered this memory
  delta_applied Json

  /// 0.0-1.0 — how extreme the triggering outcome was. Drives memory decay
  /// and trauma-modifier strength. 1.0 = top/bottom band; 0.0 = neutral.
  magnitude       Float   @default(0.5)
  /// Optional counterparty (antagonist/co-subject) used for grudge weighting.
  counterparty_id String? @db.Uuid
  /// Narrative voice this memory was written in. Optional — back-filled as null
  /// on rows older than Phase 5. New writes should always tag.
  tone            Tone?

  // ── Phase 6: retention / compression ─────────────────────
  /// Composite 0-100 weight computed at write-time from outcome band,
  /// |stat delta|, group-lifecycle flag, counterparty prominence, and
  /// event-type floors (death/birth/marriage). Used for ranking when a
  /// LifeDecadeSummary is created and for getMemoryContext top-N selects.
  weight          Int     @default(50)
  /// The 0-indexed decade of the subject's life in which this memory
  /// occurred (floor(age_at_event / 10)). Lets compressLifeDecade()
  /// slice the table by decade-of-life without recomputing ages.
  decade_of_life  Int?

  timestamp  DateTime @default(now())
  world_year Int? // the world calendar year this memory occurred in

  @@index([person_id])
  @@index([timestamp])
  @@index([world_year])
  @@index([counterparty_id])
  @@index([person_id, decade_of_life])
  @@index([person_id, weight])
  @@map("memory_bank")
}

// WorldState has been superseded by the World model above.

// --------------- Deceased Persons (RIP archive) ---------------

model DeceasedPerson {
  id                    String   @id @default(uuid()) @db.Uuid
  name                  String
  age_at_death          Int
  world_year            Int
  /// 'interaction' | 'old_age' | 'health'
  cause                 String
  final_health          Int
  final_wealth          Float
  peak_positive_outcome String?
  peak_negative_outcome String?
  died_at               DateTime @default(now())

  world    World  @relation(fields: [world_id], references: [id], onDelete: Cascade)
  world_id String @db.Uuid

  @@index([world_id])
  @@map("deceased_persons")
}

// --------------- Rulesets ---------------

model Ruleset {
  id          String   @id @default(uuid()) @db.Uuid
  name        String
  description String?
  is_active   Boolean  @default(false)
  /// Full RulesetDef JSON — interaction types, outcome bands, weights
  rules       Json
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  worlds World[]

  @@map("rulesets")
}

// --------------- Yearly Headlines ---------------

model YearlyHeadline {
  id          String           @id @default(uuid()) @db.Uuid
  /// For ANNUAL: the specific year. For DECADE: the decade start (e.g. 840 for 840–849)
  year        Int
  type        HeadlineType     @default(ANNUAL)
  category    HeadlineCategory
  headline    String
  story       String
  person_id   String?          @db.Uuid
  person_name String?
  /// Voice the narrative was written in. Decade summaries are always `epic`.
  tone        Tone             @default(neutral)
  created_at  DateTime         @default(now())

  world    World  @relation(fields: [world_id], references: [id], onDelete: Cascade)
  world_id String @db.Uuid

  @@unique([world_id, year, type, category])
  @@index([year])
  @@index([type])
  @@index([world_id])
  @@map("yearly_headlines")
}

// --------------- Religions ---------------
// Personality-cult shared entity. Dies the instant its founder dies.
// `virus_profile` is a JSONB map of trait/global-score thresholds, e.g.
//   { "charisma": { "min": 60 }, "faith.devotion": { "min": 70 } }
// Unknown keys are silently ignored by the engine.
model Religion {
  id          String  @id @default(uuid()) @db.Uuid
  name        String
  description String?

  /// Nullable so dissolved religions persist in the archive after founder death.
  founder    Person? @relation("ReligionFounder", fields: [founder_id], references: [id], onDelete: SetNull)
  founder_id String? @db.Uuid
  /// Current torchbearer — may differ from founder after succession.
  /// Round 4: on founder death, we try to promote an heir before dissolving.
  leader     Person? @relation("ReligionLeader", fields: [leader_id], references: [id], onDelete: SetNull)
  leader_id  String? @db.Uuid

  /// How the group was created. emergent / player / event
  origin        GroupOrigin @default(emergent)
  /// Tolerance band (0-100) around thresholds — softens profile matching.
  tolerance     Int         @default(10)
  /// Trait/global-score thresholds (see above comment).
  virus_profile Json        @default("{}")
  /// Wealth deducted per tick from each member (god-mode configurable).
  cost_per_tick Int         @default(0)
  /// Minimum trait values required for membership, e.g. { "intelligence": 60 }.
  trait_minimums Json       @default("{}")

  founded_year     Int
  is_active        Boolean @default(true)
  dissolved_year   Int?
  /// 'founder_death' | 'leader_void' | 'player' | 'split'
  dissolved_reason String?

  world    World  @relation(fields: [world_id], references: [id], onDelete: Cascade)
  world_id String @db.Uuid

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  memberships ReligionMembership[]

  @@index([founder_id])
  @@index([leader_id])
  @@index([is_active])
  @@index([world_id])
  @@map("religions")
}

model ReligionMembership {
  id String @id @default(uuid()) @db.Uuid

  religion    Religion @relation(fields: [religion_id], references: [id], onDelete: Cascade)
  religion_id String   @db.Uuid
  person      Person   @relation(fields: [person_id], references: [id], onDelete: Cascade)
  person_id   String   @db.Uuid

  joined_year Int
  /// 0.0-1.0 — how cleanly the member matches the current virus profile.
  alignment   Float @default(1.0)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@unique([religion_id, person_id])
  @@index([religion_id])
  @@index([person_id])
  @@map("religion_memberships")
}

// --------------- Factions ---------------
// Political/organisational group. Survives past its leader's death if a
// worthy successor exists (leadership >= gate). Can split when a member's
// profile alignment beats the leader's by more than the founder buffer.
model Faction {
  id          String  @id @default(uuid()) @db.Uuid
  name        String
  description String?

  /// Nullable so historical factions persist after founder death.
  founder    Person? @relation("FactionFounder", fields: [founder_id], references: [id], onDelete: SetNull)
  founder_id String? @db.Uuid
  /// Current leader — may differ from founder after succession or split.
  leader     Person? @relation("FactionLeader", fields: [leader_id], references: [id], onDelete: SetNull)
  leader_id  String? @db.Uuid

  origin        GroupOrigin @default(emergent)
  tolerance     Int         @default(10)
  virus_profile Json        @default("{}")
  /// Wealth deducted per tick from each member (god-mode configurable).
  cost_per_tick  Int        @default(0)
  /// Minimum trait values required for membership, e.g. { "charisma": 50 }.
  trait_minimums Json       @default("{}")

  founded_year     Int
  is_active        Boolean @default(true)
  dissolved_year   Int?
  /// 'leader_void' | 'player' | 'split' | 'merged'
  dissolved_reason String?

  /// If this faction was born from a split, the parent faction id.
  split_from_id String? @db.Uuid

  world    World  @relation(fields: [world_id], references: [id], onDelete: Cascade)
  world_id String @db.Uuid

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  memberships FactionMembership[]

  @@index([founder_id])
  @@index([leader_id])
  @@index([is_active])
  @@index([world_id])
  @@map("factions")
}

model FactionMembership {
  id String @id @default(uuid()) @db.Uuid

  faction    Faction @relation(fields: [faction_id], references: [id], onDelete: Cascade)
  faction_id String  @db.Uuid
  person     Person  @relation(fields: [person_id], references: [id], onDelete: Cascade)
  person_id  String  @db.Uuid

  joined_year          Int
  alignment            Float @default(1.0)
  /// Used by split-detection: ticks that this member's alignment has
  /// exceeded the leader's alignment by the founder-buffer margin.
  split_pressure_ticks Int   @default(0)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@unique([faction_id, person_id])
  @@index([faction_id])
  @@index([person_id])
  @@map("faction_memberships")
}

// --------------- Life Decade Summary ---------------
// Written at every birthday where age % 10 === 0 && age > 0. Compresses
// the just-completed decade of PersonMemory into a fixed-size snapshot
// (top-N by weight, tier-dependent). Raw memories in that decade are then
// deleted. Chains via prior_summary_id so a 70-year-old has 7 linked rows.
model LifeDecadeSummary {
  id String @id @default(uuid()) @db.Uuid

  person    Person @relation(fields: [person_id], references: [id], onDelete: Cascade)
  person_id String @db.Uuid

  /// Age at which this decade ended (always a multiple of 10, > 0).
  /// e.g. 30 means "the decade of life from age 20 through 29".
  decade_end_age Int
  /// Same concept as `decade_end_age / 10 - 1`; indexed for range queries.
  decade_of_life Int

  /// World year the decade began.
  world_year_start Int
  /// World year the decade ended.
  world_year_end   Int

  /// JSONB array of the top-N preserved memories for this decade.
  /// Shape: [{ event_summary, emotional_impact, tone, weight,
  ///           world_year, counterparty_id, delta_applied }]
  /// N is tier-driven: intimate=10, town=5, civilization=3.
  top_memories Json @default("[]")

  /// Aggregate stats for the decade — used by getMemoryContext to answer
  /// "what happened to X in their 30s" without re-reading raw memories.
  /// Shape: { interaction_count, avg_magnitude, peak_positive, peak_negative,
  ///          stat_deltas: { morality, influence, wealth, ... } }
  aggregates Json @default("{}")

  /// Prior decade summary (age-10 earlier). Enables decade chaining so future
  /// narration has the whole life sketch without a separate findMany call.
  prior_summary_id String? @db.Uuid

  created_at DateTime @default(now())

  @@unique([person_id, decade_end_age])
  @@index([person_id])
  @@index([person_id, decade_of_life])
  @@map("life_decade_summaries")
}

// --------------- Group Memory ---------------
// Religion/faction-scoped narrative memory. Write-once, keep-forever. Tiny
// volume (group-lifecycle events only: founded, first-member, schism, leader
// death, war). Keyed to group_id via polymorphic (group_type, group_id) so
// both religions and factions share one memory stream.
model GroupMemory {
  id String @id @default(uuid()) @db.Uuid

  /// 'religion' | 'faction'
  group_type String
  group_id   String @db.Uuid

  world_id String @db.Uuid

  event_summary   String
  event_kind      String // 'founded' | 'first_member' | 'schism' | 'leader_death' | 'war' | ...
  tone            Tone   @default(epic)
  world_year      Int
  /// 0-100 — how pivotal this was in the group's arc. Reads rank by this.
  weight          Int    @default(70)
  /// Optional counterparty group for war/schism events.
  counterparty_id String? @db.Uuid

  /// JSONB — free-form event payload (member counts, alignment deltas, etc.)
  payload Json @default("{}")

  created_at DateTime @default(now())

  @@index([group_type, group_id])
  @@index([world_id])
  @@index([world_year])
  @@map("group_memories")
}

// --------------- World Memory ---------------
// World-scale canonical events. ~0-5/year. Never decays. Read by decade
// summary prompts to thread narrative forward across centuries.
model WorldMemory {
  id String @id @default(uuid()) @db.Uuid

  world    World  @relation(fields: [world_id], references: [id], onDelete: Cascade)
  world_id String @db.Uuid

  event_summary String
  /// 'plague' | 'nuke' | 'crash' | 'religion_founded' | 'faction_founded' |
  /// 'war_declared' | 'decade_canon' | 'player_edict' | ...
  event_kind    String
  tone          Tone   @default(epic)
  world_year    Int
  /// 0-100. Reads rank by this when the table grows.
  weight        Int    @default(80)

  payload Json @default("{}")

  created_at DateTime @default(now())

  @@index([world_id])
  @@index([world_id, world_year])
  @@map("world_memories")
}

// --------------- Tick Job (Postgres-as-queue) ---------------
// Long-running work (Claude narration, decade-headline generation) is
// enqueued here and consumed by a single-worker loop using pg advisory
// locks. Synchronous tick simulation does NOT go through this queue —
// only opt-in narrative generation does.
model TickJob {
  id String @id @default(uuid()) @db.Uuid

  world    World  @relation(fields: [world_id], references: [id], onDelete: Cascade)
  world_id String @db.Uuid

  /// 'generate_year_headlines' | 'generate_decade_headlines' | ...
  kind   String
  status JobStatus @default(pending)

  /// Input payload (e.g. { year: 842, category: 'MOST_DRAMATIC_FALL' })
  payload Json @default("{}")
  /// Output on success (e.g. { headline_ids: [...] })
  result  Json?

  /// Set to a random bigint by the claiming worker and used with
  /// pg_try_advisory_lock so only one worker progresses a job at a time.
  lock_key BigInt?

  error        String?
  attempts     Int      @default(0)
  max_attempts Int      @default(3)

  created_at  DateTime  @default(now())
  started_at  DateTime?
  finished_at DateTime?

  @@index([status])
  @@index([world_id, status])
  @@index([kind, status])
  @@map("tick_jobs")
}

// --------------- Yearly Report ---------------
// Deterministic number-report written by the synchronous tick pipeline
// every game year. Cheap to generate, cheap to read, no Claude involved.
// Serves as the default Dashboard "what just happened" surface and as
// input to the opt-in headline generator.
model YearlyReport {
  id String @id @default(uuid()) @db.Uuid

  world    World  @relation(fields: [world_id], references: [id], onDelete: Cascade)
  world_id String @db.Uuid

  year              Int
  population_start  Int
  population_end    Int
  births            Int   @default(0)
  deaths            Int   @default(0)
  deaths_by_cause   Json  @default("{}") // { interaction, old_age, health }
  market_index_start Float
  market_index_end   Float

  /// Top stat swings for the year — array of
  ///   { person_id, person_name, stat, delta, from, to }
  /// Trimmed to top 10 by |delta| at write time.
  top_swings     Json @default("[]")
  /// Group lifecycle events this year
  ///   [{ group_type, group_id, name, kind }]
  group_events   Json @default("[]")
  /// Any bulk God Mode actions applied this year
  bulk_actions   Json @default("[]")
  /// Global force composite snapshot { warScore, loveScore, ... }
  force_scores   Json @default("{}")

  created_at DateTime @default(now())

  @@unique([world_id, year])
  @@index([world_id])
  @@map("yearly_reports")
}
